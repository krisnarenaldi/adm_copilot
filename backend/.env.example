# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# Use a Secret API key from Settings → API → Secret keys (preferred over legacy service_role JWT)
SUPABASE_KEY=<your-secret-api-key>

# ── JWT ───────────────────────────────────────────────────────────────────────
# A long, random secret used to sign JWTs (e.g. openssl rand -hex 32)
JWT_SECRET=wIgmtEOcD7j7f1acETmQ9EzO0gnp5sQV1cotwAzGddk
JWT_ALGORITHM=HS256

# ── Google AI (Gemma via LangChain) ───────────────────────────────────────────
GOOGLE_API_KEY=<your-google-ai-api-key>

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Integer between 1 and 100 inclusive; defaults to 5 if absent or invalid
MAX_UPLOADS_PER_DAY=5

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://<your-vercel-app>.vercel.app

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Path to the persistent ChromaDB directory inside the container
CHROMA_DB_PATH=./chroma_db
